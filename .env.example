# Written by `convex dev` after the local deployment is configured.
CONVEX_DEPLOYMENT=
CONVEX_URL=http://127.0.0.1:3210
CONVEX_SITE_URL=http://127.0.0.1:3211

# Expose the Convex client URL only when the web application starts using it.
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210

# Worker settings contain no provider credentials in the foundation scaffold.
WORKER_PORT=3212

# Optional MED-133 component-build loop. Normal development keeps this off.
# Set true only with a matching Convex URL and server-side worker token.
# Keep COMPONENT_BUILD_WORKER_TOKEN only in Convex and the worker environment.
COMPONENT_BUILD_ENABLED=false
COMPONENT_BUILD_CONVEX_URL=
COMPONENT_BUILD_WORKER_TOKEN=
COMPONENT_BUILD_WORKSPACE_ROOT=.relay/component-build-workspaces

# Optional MED-128 authoring loop. Normal development keeps this disabled.
# Fake mode is deterministic and free. Real mode additionally requires the
# explicit real-Pi flag, exact provider/model, and bounded turn budgets.
AUTHORING_ENABLED=false
AUTHORING_MODE=fake
AUTHORING_CONVEX_URL=http://127.0.0.1:3210
AUTHORING_WORKER_TOKEN=
AUTHORING_WORKSPACE_ROOT=.relay/component-authoring-workspaces
AUTHORING_PI_SESSION_ROOT=.relay/component-authoring-sessions
AUTHORING_REAL_PI_ENABLED=false
AUTHORING_PI_MODEL=
# Server-only JSON credential consumed into memory and never copied into Pi
# sessions, context, logs, or workspaces. Supply either an api_key credential
# or the provider's complete OAuth credential. Never commit a value here.
AUTHORING_PI_CREDENTIAL_JSON=

# Explicit paid smoke only. Never place provider credentials here.
AUTHORING_PI_SMOKE_CONFIRM=
AUTHORING_PI_SMOKE_MAX_WALL_MS=60000
AUTHORING_PI_SMOKE_MAX_TOKENS=4000
AUTHORING_PI_SMOKE_MAX_COST_USD=0.25
